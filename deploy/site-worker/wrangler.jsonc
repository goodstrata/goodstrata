{
  "name": "goodstrata-www",
  "main": "worker.js",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "../../site",
    "html_handling": "auto-trailing-slash",
    "binding": "ASSETS",
    // Media must hit the script so Range requests get real 206s (Safari
    // refuses <video> from hosts that answer ranges with a full-body 200).
    "run_worker_first": ["/clips/*"]
  }
}
