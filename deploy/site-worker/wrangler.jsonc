{
  "name": "goodstrata-www",
  "main": "worker.js",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "../../site",
    "html_handling": "auto-trailing-slash",
    "binding": "ASSETS",
    // Canonicalisation must happen before asset matching on every route; the
    // script still delegates assets while keeping real 206s for Safari video.
    "run_worker_first": true
  }
}
