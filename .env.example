# --- Required ---
DATABASE_URL=postgres://goodstrata:goodstrata@localhost:5434/goodstrata
BETTER_AUTH_SECRET=change-me-generate-a-long-random-string
APP_URL=http://localhost:5173

# --- Server ---
PORT=3000
NODE_ENV=development

# --- AI (defaults to "mock" — no LLM required to run) ---
# AI_PROVIDER=anthropic | local | mock
AI_PROVIDER=mock
# AI_DEFAULT_MODEL examples: anthropic:claude-sonnet-4-5 | local:qwen3:14b
AI_DEFAULT_MODEL=mock:default
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434
# Per-agent overrides (optional): AI_MODEL_FINANCE, AI_MODEL_MAINTENANCE, ...

# --- Integrations (all default to offline/local drivers) ---
# PAYMENTS_PROVIDER=mock | monoova
PAYMENTS_PROVIDER=mock
# EMAIL_PROVIDER=console | ses
EMAIL_PROVIDER=console
# SMS_PROVIDER=console | twilio
SMS_PROVIDER=console
# STORAGE_PROVIDER=local | s3
STORAGE_PROVIDER=local
# VIDEO_PROVIDER=console | daily
VIDEO_PROVIDER=console
DATA_DIR=./data

# AWS SES (if EMAIL_PROVIDER=ses)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-2
# AWS_SES_FROM_EMAIL=notices@yourdomain.com

# Twilio (if SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+61400000000

# Daily.co video rooms (if VIDEO_PROVIDER=daily)
# DAILY_API_KEY=

# Monoova (if PAYMENTS_PROVIDER=monoova)
# MONOOVA_API_KEY= MONOOVA_WEBHOOK_SECRET=

# --- Testing ---
# TEST_DATABASE_URL=postgres://goodstrata:goodstrata@localhost:5434/goodstrata_test
# RUN_LLM_EVALS=0
