# --- Required ---
DATABASE_URL=postgres://goodstrata:goodstrata@localhost:5434/goodstrata
BETTER_AUTH_SECRET=change-me-generate-a-long-random-string
APP_URL=http://localhost:5173

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Sign in with Google (optional; button hides when unset) ---
# Create an OAuth client (type "Web application") at
# https://console.cloud.google.com/apis/credentials and register the redirect
# URI  <APP_URL>/api/auth/callback/google  — e.g.
#   dev:  http://localhost:5173/api/auth/callback/google
#   prod: https://my.goodstrata.com.au/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- AI (defaults to "mock" — no LLM required to run) ---
# AI_PROVIDER=anthropic | local | mock
AI_PROVIDER=mock
# AI_DEFAULT_MODEL examples: anthropic:claude-sonnet-4-5 | local:qwen3:14b
AI_DEFAULT_MODEL=mock:default
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434
# Per-agent overrides (optional): AI_MODEL_FINANCE, AI_MODEL_MAINTENANCE, ...

# --- Integrations (all default to offline/local drivers) ---
# PAYMENTS_PROVIDER=mock | monoova
PAYMENTS_PROVIDER=mock
# EMAIL_PROVIDER=console | ses | smtp   (console = local sink, just logs)
EMAIL_PROVIDER=console
# SMS_PROVIDER=console | twilio
SMS_PROVIDER=console
# PUSH_PROVIDER=console | expo   (expo = real OS push to the member app, no creds needed)
PUSH_PROVIDER=console
# STORAGE_PROVIDER=local | s3
STORAGE_PROVIDER=local
# VIDEO_PROVIDER=console | daily
VIDEO_PROVIDER=console
DATA_DIR=./data

# AWS SES (if EMAIL_PROVIDER=ses)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-2
# AWS_SES_FROM_EMAIL=notices@yourdomain.com

# Generic SMTP (if EMAIL_PROVIDER=smtp) — point at your own mail server
# (Fastmail, Postmark SMTP, Migadu, a company relay, …). The sender address
# reuses AWS_SES_FROM_EMAIL above. SMTP_SECURE defaults to true (implicit TLS,
# port 465); set SMTP_SECURE=false for STARTTLS on port 587.
# SMTP_HOST=smtp.fastmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# AWS_SES_FROM_EMAIL=notices@yourdomain.com

# Twilio (if SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+61400000000

# Expo push (if PUSH_PROVIDER=expo) — only needed once "enhanced push
# security" is enabled for the EAS project; the endpoint is otherwise open.
# EXPO_ACCESS_TOKEN=

# Daily.co video rooms (if VIDEO_PROVIDER=daily)
# DAILY_API_KEY=

# Monoova (if PAYMENTS_PROVIDER=monoova)
# MONOOVA_API_KEY= MONOOVA_WEBHOOK_SECRET=

# --- Testing ---
# TEST_DATABASE_URL=postgres://goodstrata:goodstrata@localhost:5434/goodstrata_test
# RUN_LLM_EVALS=0
